# Strapi
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337
CORS_ORIGIN=http://localhost:8787,http://127.0.0.1:8787
BOOTSTRAP_PUBLIC_READ=true

# Security secrets: generate unique values before production.
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-me-api-token-salt
ADMIN_JWT_SECRET=replace-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-me-transfer-token-salt
JWT_SECRET=replace-me-jwt-secret
ENCRYPTION_KEY=replace-me-32-character-secret

# PostgreSQL
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=cam_museum
DATABASE_USERNAME=cam_museum
DATABASE_PASSWORD=cam_museum
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10

# Import scripts
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
EXPECTED_VEHICLE_COUNT=69
EXPECTED_CATEGORY_COUNT=13
EXPECTED_NEWS_COUNT=6
EXPECTED_EVENT_COUNT=6
EXPECTED_TICKET_TYPE_COUNT=16
EXPECTED_BOOKING_OPTION_COUNT=6
EXPECTED_VISIT_SLOT_COUNT=7
EXPECTED_MENU_ITEM_COUNT=15

# Public form protection
PUBLIC_FORM_MIN_ELAPSED_MS=1200
PUBLIC_FORM_RATE_LIMIT_MAX=8
PUBLIC_FORM_RATE_LIMIT_WINDOW_MS=900000

# Internal notifications
INTERNAL_NOTIFICATIONS_ENABLED=true
INTERNAL_NOTIFICATION_TO=operations@museeautomobile.ma
INTERNAL_NOTIFICATION_FROM=no-reply@museeautomobile.ma
INTERNAL_NOTIFICATION_REPLY_TO=contact@museeautomobile.ma
STRAPI_ADMIN_URL=http://localhost:1337
EMAIL_FROM=no-reply@museeautomobile.ma
EMAIL_PROVIDER=nodemailer
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
