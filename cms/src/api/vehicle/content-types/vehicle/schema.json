{
  "kind": "collectionType",
  "collectionName": "vehicles",
  "info": {
    "singularName": "vehicle",
    "pluralName": "vehicles",
    "displayName": "Vehicle",
    "description": "Vehicle records displayed in the museum collection."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "year": {
      "type": "integer"
    },
    "period": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "categoryLabel": {
      "type": "string"
    },
    "summary": {
      "type": "text"
    },
    "story": {
      "type": "richtext"
    },
    "specs": {
      "type": "component",
      "repeatable": true,
      "component": "vehicle.spec"
    },
    "keywords": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "legacyImagePath": {
      "type": "string"
    },
    "sourceFile": {
      "type": "string"
    },
    "sourcePdfPage": {
      "type": "integer"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.meta"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::vehicle-category.vehicle-category",
      "inversedBy": "vehicles"
    }
  }
}
