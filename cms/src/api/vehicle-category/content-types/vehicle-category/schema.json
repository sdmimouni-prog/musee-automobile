{
  "kind": "collectionType",
  "collectionName": "vehicle_categories",
  "info": {
    "singularName": "vehicle-category",
    "pluralName": "vehicle-categories",
    "displayName": "Vehicle category",
    "description": "Categories used to filter and organize the museum collection."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "categoryType": {
      "type": "enumeration",
      "enum": ["family", "period", "country", "tag"],
      "default": "tag"
    },
    "color": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "vehicles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::vehicle.vehicle",
      "mappedBy": "categories"
    }
  }
}
